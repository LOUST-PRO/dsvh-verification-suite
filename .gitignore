counterintel/
*counterintel*.md
*ip-boundary*
*proprietary*
*loust-pro-dsvh*
*f80-internal*
drafts/
.preview/
.internal/
*_private.md
*_internal.md

# Runtime / build artifacts
runtime/
build/
*.aux
*.log
*.out
*.bbl
*.blg
*.toc
*.synctex.gz
__pycache__/
*.pyc
node_modules/
target/

# Editor / OS
*.swp
*~
.DS_Store
.idea/
.vscode/

# Secrets (defense in depth)
*.key
*.pem
*.p12
*.pfx
*.kdbx
.env*
secrets/

# Worktree artifacts
.worktrees/
